# App bind address inside the container.
GO_YGG_SERVER_HOST=0.0.0.0
# Host port exposed by docker-compose for the app service.
GO_YGG_SERVER_PORT=8080
# Application database connection string.
GO_YGG_DATABASE_DSN=postgres://app:secret@db:5432/app?sslmode=disable
# Default application log level.
GO_YGG_LOG_LEVEL=info
# Default application log output format.
GO_YGG_LOG_FORMAT=json

# PostgreSQL user used by the local dev database container.
POSTGRES_USER=app
# PostgreSQL password used by the local dev database container.
POSTGRES_PASSWORD=secret
# PostgreSQL database name created on container startup.
POSTGRES_DB=app
# Host port exposed by docker-compose for PostgreSQL.
POSTGRES_PORT=5432
