package templates

templ Base(title string) {
	<!DOCTYPE html>
	<html lang="fr">
		<head>
			<meta charset="UTF-8"/>
			<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
			<title>{ title }</title>
			<link rel="stylesheet" href="/static/css/output.css"/>
			@TemplUIScripts()
		</head>
		<body class="min-h-screen bg-background text-foreground">
			{ children... }
		</body>
	</html>
}
